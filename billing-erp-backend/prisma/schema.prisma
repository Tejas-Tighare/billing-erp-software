generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

//////////////////////
// ENUMS
//////////////////////

enum Role {
  SUPER_ADMIN
  OWNER
  EMPLOYEE
}

enum SubscriptionStatus {
  ACTIVE
  EXPIRED
  CANCELLED
}

enum InventoryReason {
  SALE
  PURCHASE
  RETURN
  DAMAGE
  ADJUSTMENT
}

enum PaymentMethod {
  CASH
  UPI
  CARD
}

enum PaymentStatus {
  SUCCESS
  PENDING
  FAILED
  REFUNDED
}

enum InvoiceStatus {
  PENDING
  PAID
  CANCELLED
}

//////////////////////
// USER & STORE
//////////////////////

model User {
  id       String  @id @default(uuid())
  name     String
  email    String
  password String
  phone    String?
  role     Role

  storeId String?
  store   Store?  @relation(fields: [storeId], references: [id])

  isActive Boolean @default(true)

  invoices Invoice[] @relation("UserInvoices")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([email, storeId])
}

model Store {
  id      String  @id @default(uuid())
  name    String
  email   String  @unique
  phone   String
  address String?

  isActive Boolean @default(true)

  users      User[]
  products   Product[]
  categories Category[]
  invoices   Invoice[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  legal        StoreLegal?
  subscription Subscription?
}

model StoreLegal {
  id String @id @default(uuid())

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id])

  ownerName String
  panNumber String
  gstNumber String?

  verified Boolean @default(false)

  createdAt DateTime @default(now())
}

model Subscription {
  id String @id @default(uuid())

  storeId String @unique
  store   Store  @relation(fields: [storeId], references: [id])

  planName  String
  startDate DateTime
  endDate   DateTime

  status SubscriptionStatus
}

//////////////////////
// PRODUCT SYSTEM
//////////////////////

model Category {
  id   String @id @default(uuid())
  name String

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  products Product[]
  types    ProductType[]

  isActive Boolean @default(true)

  @@unique([storeId, name])
  @@index([storeId])
}

model ProductType {
  id   String @id @default(uuid())
  name String

  categoryId String
  category   Category @relation(fields: [categoryId], references: [id])

  products Product[]

  isActive Boolean @default(true)

  @@unique([categoryId, name])
  @@index([categoryId])
}

model Product {
  id String @id @default(uuid())

  name        String
  description String?

  brand   String?
  sku     String?
  barcode String?

  basePrice Decimal  @db.Decimal(10, 2)
  costPrice Decimal? @db.Decimal(10, 2)
  taxRate   Decimal? @db.Decimal(5, 2)

  hasVariants Boolean @default(false)

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  categoryId String?
  category   Category? @relation(fields: [categoryId], references: [id])

  typeId String?
  type   ProductType? @relation(fields: [typeId], references: [id])

  variants      ProductVariant[]
  inventoryLogs InventoryLog[]
  invoiceItems  InvoiceItem[] // ✅ FIX ADDED

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, barcode])
  @@unique([storeId, sku])
  @@index([storeId])
  @@index([barcode])
  @@index([storeId, name])
}

model ProductVariant {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  name String?

  sku     String?
  barcode String?

  price Decimal @db.Decimal(10, 2)
  stock Int

  attributes Json?

  inventoryLogs InventoryLog[]
  invoiceItems  InvoiceItem[] // ✅ FIX ADDED

  isActive Boolean @default(true)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([productId, barcode])
  @@unique([productId, sku])
}

//////////////////////
// INVENTORY
//////////////////////

model InventoryLog {
  id String @id @default(uuid())

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  change Int
  reason InventoryReason

  createdAt DateTime @default(now())

  @@index([productId])
}

//////////////////////
// BILLING
//////////////////////

model Invoice {
  id String @id @default(uuid())

  invoiceNumber String @unique

  storeId String
  store   Store  @relation(fields: [storeId], references: [id])

  createdBy String
  user      User   @relation("UserInvoices", fields: [createdBy], references: [id])

  totalAmount    Decimal  @db.Decimal(10, 2)
  taxAmount      Decimal? @db.Decimal(10, 2)
  discountAmount Decimal? @db.Decimal(10, 2)

  status InvoiceStatus

  createdAt DateTime @default(now())

  items    InvoiceItem[]
  payments Payment[]

  @@index([storeId])
  @@index([invoiceNumber])
}

model InvoiceItem {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  productId String
  product   Product @relation(fields: [productId], references: [id])

  variantId String?
  variant   ProductVariant? @relation(fields: [variantId], references: [id])

  quantity Int
  price    Decimal  @db.Decimal(10, 2)
  tax      Decimal? @db.Decimal(10, 2)

  @@index([invoiceId])
}

model Payment {
  id String @id @default(uuid())

  invoiceId String
  invoice   Invoice @relation(fields: [invoiceId], references: [id])

  amount Decimal @db.Decimal(10, 2)

  method PaymentMethod
  status PaymentStatus

  createdAt DateTime @default(now())

  @@index([invoiceId])
}
